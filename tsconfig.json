{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "commonjs",
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./build",
    "rootDir": "./src",
    "composite": false,
    "incremental": true,
    "tsBuildInfoFile": "./tsBuildInfo.json",
    "removeComments": false,
    "importHelpers": false,
    "isolatedModules": false,
    "newLine": "LF",

    /* Strict Type-Checking Options */
    "strict": true,
    "skipLibCheck": true,

    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Module Resolution Options */
    "paths": {
      "src/*": ["./src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "preserveSymlinks": true
  },
  "include": ["src/**/*"]
}
